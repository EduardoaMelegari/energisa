# Copie este arquivo para .env e preencha os valores.
# O .env NAO deve ir para o git nem para a imagem Docker.

# ===== Credenciais de acesso ao app =====
APP_USERNAME=admin
APP_PASSWORD=troque-por-uma-senha-forte

# Chave que assina o cookie de sessao. Gere uma com:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Se deixar em branco, o app gera e guarda em data/.secret_key automaticamente.
SECRET_KEY=

# 'true' = cookie de sessao so trafega em HTTPS (correto atras do tunnel).
# Use 'false' SOMENTE para testar localmente em http://localhost.
COOKIE_SECURE=true

# ===== Cloudflare Tunnel =====
# Token do tunnel: painel Zero Trust > Networks > Tunnels > (seu tunnel) > token.
TUNNEL_TOKEN=
